# Kopiere diese Datei zu ".env.local" und trage deine echten Werte ein.
# Zu finden in deinem Supabase-Projekt unter Project Settings -> API.
# Ohne diese beiden Werte läuft die App weiterhin normal, nur ohne Cloud-Sync/Login.

VITE_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=DEIN-ANON-KEY
